# Maintainer: Leandro Michelino | ACE | leandro.michelino@oracle.com
tenancy_ocid       = "ocid1.tenancy.oc1..example"
current_user_ocid  = "ocid1.user.oc1..example"
region             = "eu-frankfurt-1"
home_region        = "eu-frankfurt-1"
oci_config_profile = "DEFAULT"

org         = "acme"
environment = "dev"
region_key  = "fra"

compartment_ocid = "ocid1.compartment.oc1..example"
subnet_id        = "ocid1.subnet.oc1.eu-frankfurt-1.example"

create_network_load_balancer = false
is_private                   = true

backend_sets = {
  tcp_app = {
    policy = "FIVE_TUPLE"
    health_checker = {
      protocol = "TCP"
      port     = 8080
    }
    backends = {}
  }
}

listeners = {
  tcp_8080 = {
    backend_set_key = "tcp_app"
    port            = 8080
    protocol        = "TCP"
  }
}

policy_statements = []
