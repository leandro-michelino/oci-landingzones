# Maintainer: Leandro Michelino | ACE | leandro.michelino@oracle.com
tenancy_ocid       = "ocid1.tenancy.oc1..example"
current_user_ocid  = "ocid1.user.oc1..example"
region             = "af-johannesburg-1"
home_region        = "af-johannesburg-1"
oci_config_profile = "DEFAULT"

org         = "acme"
environment = "prod"
region_key  = "jnb"

# Keep real compartment, VCN, subnet, image, and SSH values in local ignored tfvars.
# compartment_ocid = "ocid1.compartment.oc1..example"
# vcn_id            = "ocid1.vcn.oc1..example"
# endpoint_subnet_id = "ocid1.subnet.oc1..example"
# node_subnet_ids    = ["ocid1.subnet.oc1..example"]

enable_cluster   = false
enable_node_pool = false
cluster_label    = "platform"
node_pool_label  = "workers"

# Required when enabling OKE creation.
# kubernetes_version = "v1.xx.x"
# node_shape         = "VM.Standard.E4.Flex"
# node_shape_ocpus   = 2
# node_shape_memory_in_gbs = 16

defined_tags = {
  "acme-tags.Environment" = "prod"
  "acme-tags.ManagedBy"   = "terraform"
  "acme-tags.Owner"       = "platform-team"
  "acme-tags.Project"     = "landingzone"
}

freeform_tags = {
  Extension = "oke"
}
