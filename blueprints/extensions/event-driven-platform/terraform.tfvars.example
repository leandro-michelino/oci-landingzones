# Maintainer: Leandro Michelino | ACE | leandro.michelino@oracle.com
tenancy_ocid      = "ocid1.tenancy.oc1..example"
current_user_ocid = "ocid1.user.oc1..example"
region            = "us-ashburn-1"
home_region       = "us-ashburn-1"
org               = "acme"
environment       = "dev"
region_key        = "iad"

create_archive_bucket    = false
create_stream_pool       = false
create_streams           = false
create_topic             = false
create_event_rules       = false
create_service_connector = false

event_rules = {
  object_to_stream = {
    condition = "{\"eventType\":[\"com.oraclecloud.objectstorage.createobject\"]}"
    actions = [
      {
        action_type = "OSS"
        stream_key  = "events"
      }
    ]
  }
}

policy_statements = []
