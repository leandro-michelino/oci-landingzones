# Maintainer: Leandro Michelino | ACE | leandro.michelino@oracle.com
tenancy_ocid       = "ocid1.tenancy.oc1..example"
current_user_ocid  = "ocid1.user.oc1..example"
region             = "af-johannesburg-1"
home_region        = "af-johannesburg-1"
oci_config_profile = "DEFAULT"

org         = "acme"
environment = "prod"
region_key  = "jnb"

# Keep real compartment, subnet, certificate, and backend values in local ignored tfvars.
# compartment_ocid = "ocid1.compartment.oc1..example"
# subnet_id         = "ocid1.subnet.oc1..example"

enable_gateway    = false
enable_deployment = false
gateway_label     = "public"
endpoint_type     = "PUBLIC"
path_prefix       = "/api"

routes = [
  {
    path         = "/health"
    methods      = ["GET"]
    backend_type = "HTTP_BACKEND"
    backend_url  = "https://example.com/health"
  }
]

defined_tags = {
  "acme-tags.Environment" = "prod"
  "acme-tags.ManagedBy"   = "terraform"
  "acme-tags.Owner"       = "platform-team"
  "acme-tags.Project"     = "landingzone"
}

freeform_tags = {
  Extension = "apigw"
}
