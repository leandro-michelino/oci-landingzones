# Maintainer: Leandro Michelino | ACE | leandro.michelino@oracle.com
tenancy_ocid      = "ocid1.tenancy.oc1..example"
current_user_ocid = "ocid1.user.oc1..example"
region            = "eu-frankfurt-1"
home_region       = "eu-frankfurt-1"
# Optional OCI CLI profile for local execution.
# oci_config_profile = "DEFAULT"

org         = "acme"
environment = "dev"
region_key  = "fra"

# Optional. Defaults to tenancy_ocid when omitted.
# For ephemeral tests, set this to the approved test compartment OCID in a local
# terraform.tfvars file that is not committed.
# parent_compartment_ocid = "ocid1.compartment.oc1..example"

enable_delete = true

defined_tags = {
  "acme-tags.Environment" = "dev"
  "acme-tags.ManagedBy"   = "terraform"
  "acme-tags.Owner"       = "platform-team"
  "acme-tags.Project"     = "landingzone"
}

freeform_tags = {}

tag_default_values = {
  Environment = "dev"
  ManagedBy   = "terraform"
  Owner       = "platform-team"
  Project     = "landingzone"
  Blueprint   = "core"
  CostCenter  = "unset"
  CreatedDate = "unset"
}

# Optional override, useful for ephemeral tests.
# tag_namespace_name = "acme-tags"

# Ephemeral test acceleration. Keep these enabled for normal landing zone
# deployments, but disable tagging for fast create/destroy tests that only need
# to validate compartments, IAM, networking, or policy wiring.
# enable_tagging      = true
# enable_tag_defaults = true

# Governance logging. Core creates log groups by default. Service logs and VCN
# flow logs require real source resource OCIDs, so keep them in local ignored
# tfvars files for each environment.
# enable_logging = true
#
# enable_audit_retention      = false
# audit_retention_period_days = 365
#
# vcn_flow_logs = {
#   hub_vcn = {
#     resource_id      = "ocid1.vcn.oc1.eu-frankfurt-1.example"
#     compartment_ocid = "ocid1.compartment.oc1..example"
#   }
# }
#
# service_logs = {
#   object_storage_write = {
#     log_group_key = "service"
#     service       = "objectstorage"
#     category      = "write"
#     resource_id   = "ocid1.bucket.oc1.eu-frankfurt-1.example"
#   }
# }

# Cloud Guard is opt-in for generic core because it is tenancy-wide. CIS
# wrappers enable it by default. Add approved detector/responder recipe OCIDs in
# local ignored tfvars files when the target should attach custom recipes.
# cloud_guard_enabled = false
#
# cloud_guard_detector_recipe_ids = [
#   "ocid1.cloudguarddetectorrecipe.oc1..example"
# ]
#
# cloud_guard_responder_recipe_ids = [
#   "ocid1.cloudguardresponderrecipe.oc1..example"
# ]

# Optional IAM overrides.
# enable_default_iam_groups     = true
# enable_default_dynamic_groups = true
# enable_default_iam_policies   = true
