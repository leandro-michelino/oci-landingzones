# Maintainer: Leandro Michelino | ACE | leandro.michelino@oracle.com
tenancy_ocid      = "ocid1.tenancy.oc1..example"
current_user_ocid = "ocid1.user.oc1..example"
region            = "eu-frankfurt-1"
home_region       = "eu-frankfurt-1"
# Optional OCI CLI profile for local execution.
# oci_config_profile = "DEFAULT"

org         = "acme"
environment = "dev"
region_key  = "fra"

# Optional. Defaults to tenancy_ocid when omitted.
# For ephemeral tests, set this to the approved test compartment OCID in a local
# terraform.tfvars file that is not committed.
# parent_compartment_ocid = "ocid1.compartment.oc1..example"

enable_delete = true

defined_tags = {
  "acme-tags.Environment" = "dev"
  "acme-tags.ManagedBy"   = "terraform"
  "acme-tags.Owner"       = "platform-team"
  "acme-tags.Project"     = "landingzone"
}

freeform_tags = {}

tag_default_values = {
  Environment = "dev"
  ManagedBy   = "terraform"
  Owner       = "platform-team"
  Project     = "landingzone"
  Blueprint   = "core"
  CostCenter  = "unset"
  CreatedDate = "unset"
}

# Optional override, useful for ephemeral tests.
# tag_namespace_name = "acme-tags"

# Ephemeral test acceleration. Keep these enabled for normal landing zone
# deployments, but disable tagging for fast create/destroy tests that only need
# to validate compartments, IAM, networking, or policy wiring.
# enable_tagging      = true
# enable_tag_defaults = true

# Governance logging. Core creates log groups by default. Service logs and VCN
# flow logs require real source resource OCIDs, so keep them in local ignored
# tfvars files for each environment.
# enable_logging = true
#
# enable_audit_retention      = false
# audit_retention_period_days = 365
#
# vcn_flow_logs = {
#   hub_vcn = {
#     resource_id      = "ocid1.vcn.oc1.eu-frankfurt-1.example"
#     compartment_ocid = "ocid1.compartment.oc1..example"
#   }
# }
#
# service_logs = {
#   object_storage_write = {
#     log_group_key = "service"
#     service       = "objectstorage"
#     category      = "write"
#     resource_id   = "ocid1.bucket.oc1.eu-frankfurt-1.example"
#   }
# }

# Cloud Guard is opt-in for generic core because it is tenancy-wide. CIS
# wrappers enable it by default. Add approved detector/responder recipe OCIDs in
# local ignored tfvars files when the target should attach custom recipes.
# cloud_guard_enabled = false
#
# cloud_guard_detector_recipe_ids = [
#   "ocid1.cloudguarddetectorrecipe.oc1..example"
# ]
#
# cloud_guard_responder_recipe_ids = [
#   "ocid1.cloudguardresponderrecipe.oc1..example"
# ]

# Vault and KMS are opt-in for generic core because they create regional
# security resources and keys. Keep customer-managed key choices in local
# ignored tfvars files.
# vault_enabled = true
#
# vault_keys = {
#   database = {
#     vault_key = "default"
#   }
# }

# Security Zones are opt-in because they enforce guardrails on protected
# compartments. Provide an approved security recipe OCID or display-name lookup
# before enabling the default landing zone Security Zone.
# security_zones_enabled = true
# default_security_zone_recipe_id = "ocid1.securityzonesrecipe.oc1..example"
# default_security_zone_recipe_display_name = "Approved Security Recipe"

# Vulnerability Scanning is opt-in for generic core. The default host scan
# recipe targets the workloads compartment; container scans can be added when
# OCIR repositories are approved.
# vss_enabled = true
#
# container_scan_recipes = {
#   ocir = {}
# }
#
# container_scan_targets = {
#   workloads = {
#     container_scan_recipe_key = "ocir"
#     registry_compartment_ocid = "ocid1.compartment.oc1..example"
#     repositories              = ["team/app"]
#   }
# }

# Governance budgets are opt-in because they need approved thresholds and
# recipients. The default budget targets the landing zone root compartment.
# enable_budgets        = true
# default_budget_amount = 5000
# default_budget_alert_recipients = [
#   "platform-alerts@example.com"
# ]
#
# budgets = {
#   workloads = {
#     amount  = 2500
#     targets = ["ocid1.compartment.oc1..example"]
#     alert_rules = {
#       warning = {
#         threshold  = 80
#         recipients = "platform-alerts@example.com"
#       }
#     }
#   }
# }

# Governance events are opt-in for generic core. CIS wrappers enable the default
# governance event rules and topic by default. Add subscriptions from local
# ignored tfvars so real endpoints are not committed.
# enable_events = true
#
# event_subscriptions = {
#   platform_email = {
#     protocol = "EMAIL"
#     endpoint = "platform-alerts@example.com"
#   }
# }
#
# event_rules = {
#   custom_governance = {
#     condition = "{\"eventType\":[\"com.oraclecloud.identityControlPlane.UpdatePolicy\"]}"
#     actions = [
#       {
#         action_type = "ONS"
#         topic_key   = "default"
#       }
#     ]
#   }
# }

# Monitoring alarms are opt-in. Create the default topic and add subscriptions
# and alarms from local ignored tfvars so real endpoints are not committed.
# monitoring_enabled = true
#
# monitoring_subscriptions = {
#   platform_email = {
#     protocol = "EMAIL"
#     endpoint = "platform-alerts@example.com"
#   }
# }
#
# monitoring_alarms = {
#   high_cpu = {
#     namespace              = "oci_computeagent"
#     query                  = "CpuUtilization[1m].mean() > 80"
#     destination_topic_keys = ["default"]
#   }
# }

