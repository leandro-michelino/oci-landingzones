# Maintainer: Leandro Michelino | ACE | leandro.michelino@oracle.com
tenancy_ocid      = "ocid1.tenancy.oc1..example"
current_user_ocid = "ocid1.user.oc1..example"
region            = "eu-frankfurt-1"
home_region       = "eu-frankfurt-1"
# oci_config_profile = "DEFAULT"
# parent_compartment_ocid = "ocid1.compartment.oc1..example"

org         = "acme"
environment = "dev"
region_key  = "fra"

defined_tags = {
  "acme-tags.Environment" = "dev"
  "acme-tags.ManagedBy"   = "terraform"
  "acme-tags.Owner"       = "platform-team"
  "acme-tags.Project"     = "landingzone"
  "acme-tags.Compliance"  = "cis-level1"
}

freeform_tags = {}

# CIS blueprints enable tenancy audit retention by default.
enable_audit_retention      = true
audit_retention_period_days = 365

# CIS blueprints enable Cloud Guard by default. Add approved detector/responder
# recipe OCIDs in local ignored tfvars files when custom recipes should be
# attached to the default landing zone target.
cloud_guard_enabled = true

# Vault/KMS and Security Zones are available from the CIS wrapper, but remain
# opt-in because they need approved key and recipe decisions.
# vault_enabled = true
#
# security_zones_enabled = true
# default_security_zone_recipe_id = "ocid1.securityzonesrecipe.oc1..example"

# VSS and monitoring alarms are available from the CIS wrapper, but remain
# opt-in so teams can approve scan scope and notification destinations.
# vss_enabled = true
#
# monitoring_enabled = true
# monitoring_subscriptions = {
#   platform_email = {
#     protocol = "EMAIL"
#     endpoint = "platform-alerts@example.com"
#   }
# }

# CIS wrappers enable governance Events by default and create a default
# notification topic/rules. Add subscriptions from local ignored tfvars so real
# endpoints are not committed.
enable_events = true

# event_subscriptions = {
#   platform_email = {
#     protocol = "EMAIL"
#     endpoint = "platform-alerts@example.com"
#   }
# }

# Budgets need approved thresholds, so they are created only when budget_amount
# or custom budgets are supplied.
# budget_amount = 5000
# budget_alert_recipients = [
#   "platform-alerts@example.com"
# ]
