# Maintainer: Leandro Michelino | ACE | leandro.michelino@oracle.com
tenancy_ocid       = "ocid1.tenancy.oc1..example"
region             = "af-johannesburg-1"
home_region        = "af-johannesburg-1"
oci_config_profile = "DEFAULT"

org         = "acme"
environment = "prod"
region_key  = "jnb"

# Keep real test compartment OCIDs in local, ignored terraform.tfvars files.
# parent_compartment_ocid = "ocid1.compartment.oc1..example"

workload_code = "payments"
workload_name = "Payments"

child_compartments = {
  app = {
    description = "Payments application compute and runtime resources."
  }
  data = {
    description = "Payments database, storage, and data services."
  }
  ops = {
    description = "Payments monitoring, automation, and operational resources."
  }
}

defined_tags = {
  "acme-tags.Environment" = "prod"
  "acme-tags.ManagedBy"   = "terraform"
  "acme-tags.Owner"       = "payments-team"
  "acme-tags.Project"     = "payments"
}

freeform_tags = {
  CostCenter = "payments"
}
